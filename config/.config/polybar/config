; all themes include a colors file
[colors]
include-file = ~/.config/polybar/colors

[bar/top]
;monitor = ${env:MONITOR:HDMI-1}
dpi = 133
include-file = ~/.config/polybar/top-bar

[bar/top-second]
dpi = 133
include-file = ~/.config/polybar/top-second-bar

[bar/bottom-launcher]
dpi = 133
include-file = ~/.config/polybar/bottom-launcher

[bar/i3top]
monitor = eDP-1
dpi = 133
include-file = ~/.config/polybar/i3-top

[bar/i3secondtop]
monitor = eDP-1
dpi = 133
include-file = ~/.config/polybar/i3-second-top

[bar/i3bottom]
monitor = eDP-1
dpi = 133
include-file = ~/.config/polybar/i3-bottom

[module/bspwm]
type = internal/bspwm
label-focused = %index%
label-focused-background = ${colors.background-alt}
label-focused-underline= ${colors.primary}
label-focused-padding = 3
label-occupied = %index%
label-occupied-padding = 3
label-urgent = %index%!
label-urgent-background = ${colors.background-alt}
label-urgent-padding = 3
label-empty = %index%
label-empty-foreground = ${colors.foreground-alt}
label-empty-padding = 3
; label-separator = |

[module/i3]
type = internal/i3
format = <label-state> <label-mode>
index-sort = true
wrapping-scroll = false
include-file = ~/.config/polybar/i3-name
label-mode-padding = 2
label-mode-foreground = ${colors.foreground-alt}
label-mode-background = ${colors.primary}
; focused = Active workspace on focused monitor
label-focused-foreground = ${colors.foreground}
label-focused-background = ${colors.desktop}
label-focused-underline = ${module/bspwm.label-focused-underline}
label-focused-padding = ${module/bspwm.label-focused-padding}
; unfocused = Inactive workspace on any monitor
label-unfocused-padding = ${module/bspwm.label-occupied-padding}
; visible = Active workspace on unfocused monitor
label-visible-background = ${self.label-focused-background}
label-visible-underline = ${self.label-focused-underline}
label-visible-padding = ${self.label-focused-padding}
; urgent = Workspace with urgency hint set
label-urgent-foreground = ${colors.alert}
label-urgent-background = ${module/bspwm.label-urgent-background}
label-urgent-padding = ${module/bspwm.label-urgent-padding}
; Separator in between workspaces
; label-separator = |

[module/runBrave]
type = custom/text
content = " ÓėĮ  "
content-foreground = ${colors.alert}
click-left = "brave-sec"

[module/runMail]
type = custom/text
content = " ÓÉ°  "
content-foreground = ${colors.alert}
click-left = "kitty -e mutt"

[module/runMsf]
type = custom/text
content = " Ó£Ę  "
content-foreground = ${colors.alert}
click-left = "kitty -e msfconsole"

[module/runWireshark]
type = custom/text
content = " ÓĘŅ  "
content-foreground = ${colors.alert}
click-left = "wireshark"

[module/uptime]
type = custom/script
exec = uptime|awk '{print $2 " " $3 " " $4 " " $5 " " $6}'|cut -d ',' -f -2
interval = 6
format-prefix = "ÓĆ† "
format-prefix-foreground = ${colors.primary}
format-foreground = ${colors.foreground}
format-padding = 1

[module/netstat]
type = internal/network
interface = wlp2s0
interval = 3.0
label-connected = %{F#ff0000}Óóė %{F-}%upspeed% %{F#00ff00}Óóõ %{F-}%downspeed%

[module/tor]
type = custom/script
exec = ~/.config/polybar/status tor
interval = 6

[module/rldTor]
type = custom/text
content = Ó°®
content-foreground = ${colors.primary}
content-padding = 0
; need into /etc/sudoers line bellow to work
; username ALL=(ALL) NOPASSWD: /usr/bin/systemctl restart tor
click-left = "sudo systemctl restart tor"

[module/dns]
type = custom/script
exec = ~/.config/polybar/status dnscrypt-proxy
interval = 6

[module/hostname]
type = custom/script
interval = 256
format = "<label> "
format-prefix = " ÓÄô "
format-prefix-foreground = ${colors.secondary}
format-padding = 0
exec = echo "$(uname -n)"

[module/ip]
type = custom/script
interval = 2
format = "<label>"
format-prefix = "ip: "
format-prefix-foreground = ${colors.primary}
format-padding = 1
exec = echo "$(wget -qO- https://canihazip.com/s | sed -e 's/[^[:digit:]\|.]//g')"
exec-if = ping -c 1 gentoo.org

[module/xwindow]
type = internal/xwindow
label = " %title:0:15:...%"
label-foreground = ${colors.foreground}

[module/mpd]
type = internal/mpd
host = 127.0.0.1
port = 6600
format-online =  <icon-prev> <toggle> <icon-next>

icon-prev = ÓĀÖ
icon-play = ÓÄ∑
icon-pause = ÓÄī
icon-next = ÓĀĄ

toggle-on-foreground = ${colors.primary}
toggle-off-foreground = ${colors.secondary}
label-offline = no sound

[module/mpd-music]
