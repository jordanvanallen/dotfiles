# i3 config file (v4)
#
# Please see https://i3wm.org/docs/userguide.html for a complete reference!
#

# --- Variables ---
#
# -- Mod keys
set $mod   Mod1
set $hyper Mod4
#
# -- Window management sizing
set $resize_increment 10
set $gap_size         15
#
# -- Audio
set $audio_increment 5
set $sink_volume     0
#
# -- Executables
set $terminal kitty
set $rofi_command rofi -show run -show-icons -sidebar-mode -terminal $terminal
#
# -- Workspaces
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

# --- General Settings ---
#
# -- Font
font DejaVu Sans Mono 12
#
# -- Mouse
focus_follows_mouse no
#
# -- Removes borders
for_window [class="^.*"] border pixel 0

# --- i3 Keybinds ---
#
# -- Reload config
bindsym $hyper+Shift+c reload
# -- Restart i3 inplace (preserves your layout/session, can be used to upgrade i3)
bindsym $hyper+Shift+r restart
# -- Exit i3 (logs you out of your X session)
bindsym $hyper+Shift+e exec "i3-nagbar -t warning -m 'You pressed the exit shortcut. Do you really want to exit i3? This will end your X session.' -b 'Yes, exit i3' 'i3-msg exit'"

# --- Window Settings ---
#
# -- Gaps
gaps inner $gap_size
gaps outer $gap_size

# --- Window/Container Management ---
#
# -- Focus
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right
bindsym $mod+a focus parent
bindsym $mod+d focus child
#
# -- Move within workspace
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right
#
# -- Resize
bindsym $hyper+h resize shrink width $resize_increment px or $resize_increment ppt
bindsym $hyper+j resize grow height $resize_increment px or $resize_increment ppt
bindsym $hyper+k resize shrink height $resize_increment px or $resize_increment ppt
bindsym $hyper+l resize grow width $resize_increment px or $resize_increment ppt
#
# -- Splits
bindsym $mod+v split h
bindsym $mod+s split v
#
# -- Fullscreen
bindsym $mod+f fullscreen toggle
#
# -- Floating
# Use Mouse+$mod to drag floating windows to their wanted position
floating_modifier $mod
# Toggle floating mode for container
bindsym $mod+Shift+space floating toggle
# Change focus between tiling / floating windows
bindsym $hyper+space focus mode_toggle
#
# -- Container layout
# * Currently these are un-used
# bindsym $hyper+s layout stacking
# bindsym $hyper+w layout tabbed
# bindsym $hyper+e layout toggle split
#
# -- Kill
bindsym $mod+Shift+q kill

# --- Workspaces ---
#
# -- Switch workspace
bindsym $hyper+1 workspace $ws1
bindsym $hyper+2 workspace $ws2
bindsym $hyper+3 workspace $ws3
bindsym $hyper+4 workspace $ws4
bindsym $hyper+5 workspace $ws5
bindsym $hyper+6 workspace $ws6
bindsym $hyper+7 workspace $ws7
bindsym $hyper+8 workspace $ws8
bindsym $hyper+9 workspace $ws9
bindsym $hyper+0 workspace $ws10
#
# -- Move focused container to workspace
bindsym $hyper+Shift+1 move container to workspace $ws1
bindsym $hyper+Shift+2 move container to workspace $ws2
bindsym $hyper+Shift+3 move container to workspace $ws3
bindsym $hyper+Shift+4 move container to workspace $ws4
bindsym $hyper+Shift+5 move container to workspace $ws5
bindsym $hyper+Shift+6 move container to workspace $ws6
bindsym $hyper+Shift+7 move container to workspace $ws7
bindsym $hyper+Shift+8 move container to workspace $ws8
bindsym $hyper+Shift+9 move container to workspace $ws9
bindsym $hyper+Shift+0 move container to workspace $ws10

# --- Executables ---
#
# -- Terminal
bindsym $hyper+Return exec --no-startup-id $terminal
#
# -- Rofi program launcher
bindsym $mod+space exec --no-startup-id $rofi_command
#
# -- Lockscreen
bindsym $mod+Shift+x exec betterlockscreen -l dim

# --- Audio ---
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume $sink_volume +$audio_increment%
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume $sink_volume -$audio_increment%
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute $sink_volume toggle

# --- Startup ---
#
# -- Background
exec_always --no-startup-id source ~/.fehbg
#
# -- Redshift
exec_always --no-startup-id redshift-gtk -O 5000
#
# -- Picom
exec_always --no-startup-id picom -b
