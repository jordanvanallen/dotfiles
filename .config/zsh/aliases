# Unix Command Overrides
alias dd='dd status=progress'
alias top='vtop'
alias ls='exa --icons'
alias la='exa -la --icons'
alias magit='vim -c MagitOnly'
alias guard='guard --no-bundler-warning'
alias vi="nvim"
alias rspec="bundle exec rspec --format documentation"

# Config Aliases
alias zshconfig="vi ~/dotfiles/.zshrc"
alias ohmyzshconfig="vi ~/.oh-my-zsh"
alias viconfig="vi ~/dotfiles/.vimrc"

# Sourcing
alias sourcezsh="source ~/.zshrc"

# Handy
alias weather='curl wttr.in'
alias yt="mpv"
alias lock="betterlockscreen -l dim"
alias covid="curl https://trackercli.com"
alias covid_canada="curl https://trackercli.com/canada"

# Git
alias st='git status'
