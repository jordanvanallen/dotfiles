# Reload functions
super + Escape
	"$XDG_CONFIG_HOME"/sxhkd/functions

Super key + enter


XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume $sink_volume +$audio_increment%
XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume $sink_volume -$audio_increment%
XF86AudioMute exec --no-startup-id pactl set-sink-mute $sink_volume toggle

