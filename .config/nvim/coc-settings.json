{
  "codeLens.enable": true,

  "languageserver": {
    "golang": {
      "command": "gopls",
      "rootPatterns": ["go.mod", ".vim/", ".git", ".hg"],
      "filetypes": ["go"]
    }
  },

  // smartf
  "smartf.timeout": 750,
  "smartf.wordJump": false,

  // yank
  "yank.highlight.duration": 300
}
